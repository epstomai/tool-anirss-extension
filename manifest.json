{
  "manifest_version": 3,
  "name": "Ani-RSS Mikan 订阅助手",
  "version": "1.3.5",
  "description": "在蜜柑计划（Mikan）页面一键把番剧订阅添加到 Ani-RSS",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Ani-RSS 订阅助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://mikanani.me/*",
        "*://*.mikanani.me/*",
        "*://mikanime.tv/*",
        "*://*.mikanime.tv/*",
        "*://mikan.tangbai.cc/*"
      ],
      "js": [
        "content/mikan.js"
      ],
      "css": [
        "content/mikan.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "popup/popup.html",
    "open_in_tab": false
  }
}
